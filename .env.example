# TapTaxi License Bot — Environment Variables

# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_bot_token_here

# Telegram user IDs of admins (comma-separated)
# Required only when AUTO_APPROVE=false
ADMIN_IDS=123456789

# Auto-issue license code immediately after receiving device_id (no manual /approve)
AUTO_APPROVE=true

# Secret key for HMAC license generation
# IMPORTANT: Must be the same key baked into the APK!
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_super_secret_key_min_32_chars

# Path to SQLite database
DB_PATH=data/licenses.db
